# ── Backend ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Inside docker compose the host is the mongo service name; locally use localhost.
MONGO_URI=mongodb://mongo:27017/mini-apty
# Must be long & random in any real deployment (min 16 chars enforced by Zod).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
CORS_ORIGIN=*

# ── Extension (build-time, inlined by Vite) ────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
